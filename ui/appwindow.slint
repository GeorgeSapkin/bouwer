import {
    Button,
    ComboBox,
    GroupBox,
    HorizontalBox,
    LineEdit,
    ListView,
    Palette,
    ProgressIndicator,
    ScrollView,
    Switch,
    TabWidget,
    TextEdit,
    VerticalBox,
} from "std-widgets.slint";

import { AboutDialog } from "about.slint";
import { EditableComboBox } from "combobox.slint";
import { Notification } from "notification.slint";
import { Tooltip } from "tooltip.slint";

global Constants {
    in-out property <length> autocomplete_element_height: 40px;
}

export component AppWindow inherits Window {
    in property <bool> busy: false;
    in property <bool> image_exists: false;
    in property <bool> notification_is_error: false;
    in property <bool> notification_is_warning: false;
    in property <bool> profiles_fetch_failed: false;
    in property <[string]> profiles: [];
    in property <float> progress_value: 0.0;
    in property <bool> progress_visible: false;
    in property <string> removed_packages_text: "";
    in property <string> selected_id: "";
    in property <string> selected_model: "";
    in property <string> selected_target: "";
    in property <string> version: "";
    in property <[string]> versions: [];

    in-out property <string> build_path_text: "";
    in-out property <string> build_status: "";
    in-out property <int> current_highlighted_profile_index: -1;
    in-out property <string> disabled_service_text: "";
    in-out property <string> extra_image_name_text: "";
    in-out property <string> notification: "";
    in-out property <string> overlay_path_text: "";
    in-out property <string> packages_text: "";
    in-out property <string> rootfs_size_value: "";
    in-out property <string> search_text: "";
    in-out property <bool> show_about: false;
    in-out property <bool> show_rcs: false;

    callback build_path_edited(string);
    callback build_requested(string);
    callback download_requested();
    callback load_preset_requested();
    callback open_build_folder_requested();
    callback open_github_link();
    callback packages_edited(string);
    callback profile_search_edited(string);
    callback profile_search_key_pressed(KeyEvent) -> bool;
    callback profile_selected(string);
    callback request_profile_search_focus();
    callback save_preset_requested(string, string, string, string, string, string, string);
    callback select_build_folder_requested();
    callback select_overlay_folder_requested();
    callback show_rcs_toggled(bool);
    callback version_changed(string);

    request_profile_search_focus => {
        profile_combo.focus();
    }

    title: "Bouwer";
    icon: @image-url("../assets/logo_no_shadow.svg");
    min-width: 700px;
    min-height: 700px;

    AboutDialog {
        show <=> root.show_about;
        version: root.version;
        z: 1000;

        open_github_link => {
            root.open_github_link();
        }
    }

    Notification {
        text <=> root.notification;
        is_error: root.notification_is_error;
        is_warning: root.notification_is_warning;
    }

    VerticalBox {
        spacing: 10px;

        HorizontalBox {
            padding: 0px;
            version_text := Text {
                text: "Version:";
                font-size: 14px;
                horizontal-alignment: right;
                vertical-alignment: center;
                width: 55px;
            }

            version_combo := ComboBox {
                model: versions;
                enabled: !busy;
                horizontal-stretch: 1;
                selected(val) => {
                    version_changed(val);
                }
            }

            Switch {
                text: "Show pre-release versions";
                enabled: !busy;
                checked <=> show_rcs;
                toggled => {
                    show_rcs_toggled(self.checked);
                }
            }

            about_icon := Rectangle {
                width: 30px;
                height: 30px;
                border-radius: 4px;
                background: about_touch.has-hover ? Palette.alternate-background : transparent;
                animate background {
                    duration: 150ms;
                    easing: ease-in-out;
                }

                Image {
                    source: @image-url("../assets/logo.svg");
                    width: 24px;
                    height: 24px;
                    horizontal-alignment: center;
                    image-rendering: pixelated;
                }

                about_touch := TouchArea {
                    clicked => {
                        root.show_about = true;
                    }
                }
            }
        }

        HorizontalBox {
            padding: 0px;
            z: 1;
            Text {
                text: "Profile:";
                font-size: 14px;
                horizontal-alignment: right;
                vertical-alignment: center;
                width: version_text.width;
            }

            profile_combo := EditableComboBox {
                text <=> search_text;
                placeholder-text: "Type to search...";
                current-index <=> current_highlighted_profile_index;
                enabled: !busy && versions.length > 0 && !profiles_fetch_failed;
                horizontal-stretch: 1;
                model: profiles;
                is-open: profiles.length > 0 && selected_id == "";
                item-height: Constants.autocomplete_element_height;

                edited(text) => {
                    profile_search_edited(text);
                }
                key_pressed(event) => {
                    return profile_search_key_pressed(event);
                }
                selected(item) => {
                    profile_selected(item);
                }
            }
        }

        HorizontalBox {
            padding: 0px;
            Rectangle {
                horizontal-stretch: 1;
            }

            download_button := Button {
                text: "Download image builder";
                enabled: !busy && selected_id != "" && !image_exists;
                primary: selected_id != "" && !image_exists;
                clicked => {
                    download_requested();
                }
            }

            load_preset_button := Button {
                text: "Load preset";
                enabled: !busy && !profiles_fetch_failed;
                clicked => {
                    load_preset_requested();
                }
            }

            save_preset_button := Button {
                text: "Save preset";
                enabled: !busy && image_exists && !profiles_fetch_failed;
                clicked => {
                    save_preset_requested(
                        root.selected_target,
                        root.selected_id,
                        root.extra_image_name_text,
                        root.rootfs_size_value,
                        root.packages_text,
                        root.disabled_service_text,
                        root.overlay_path_text,
                    );
                }
            }
        }

        Rectangle {
            background: Palette.control-background;
            border-width: 1px;
            border-color: Palette.border;
            border-radius: 4px;
            GridLayout {
                padding: 10px;
                spacing: 6px;
                Row {
                    Text {
                        text: "Model:";
                        width: 45px;
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: right;
                    }

                    Text {
                        text: selected_model;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }

                Row {
                    Text {
                        text: "ID:";
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: right;
                    }

                    Text {
                        text: selected_id;
                        font-size: 12px;
                    }
                }

                Row {
                    Text {
                        text: "Target:";
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: right;
                    }

                    Text {
                        text: selected_target;
                        font-size: 12px;
                    }
                }
            }
        }

        TabWidget {
            Tab {
                title: "General settings";

                VerticalBox {
                    padding: 0px;
                    padding-top: 10px;

                    HorizontalBox {
                        padding: 0px;
                        z: 100;

                        extra_image_rect := Rectangle {
                            extra_image_label := Text {
                                text: "Extra image name:";
                                font-size: 14px;
                                vertical-alignment: center;
                            }

                            extra_image_touch := TouchArea {
                                width: extra_image_rect.width;
                                height: extra_image_rect.height;

                                extra_image_tooltip := Tooltip {
                                    text: "Extra name appended to the generated firmware image filenames.";
                                    active: extra_image_touch.has-hover;
                                    x: 0;
                                    y: parent.height + 8px;
                                }
                            }
                        }

                        extra_image_name := LineEdit {
                            text <=> extra_image_name_text;
                            enabled: !busy && image_exists;
                            placeholder_text: "none";
                        }
                    }

                    packages_rect := Rectangle {
                        z: 90;
                        HorizontalBox {
                            padding: 0px;
                            Text {
                                text: "Packages:";
                                font-size: 14px;
                                horizontal-alignment: left;
                            }
                        }

                        packages_touch := TouchArea {
                            width: packages_rect.width;
                            height: packages_rect.height;

                            packages_tooltip := Tooltip {
                                text: "Space-separated list of packages to include in the firmware.";
                                active: packages_touch.has-hover;
                                x: 0;
                                y: parent.height + 8px;
                            }
                        }
                    }

                    packages_text := TextEdit {
                        text <=> root.packages_text;
                        enabled: !busy && image_exists;
                        min-height: 60px;
                        placeholder-text: "none";
                        edited(text) => {
                            packages_edited(text);
                        }
                    }

                    removed_packages_rect := Rectangle {
                        z: 80;

                        VerticalBox {
                            padding: 0px;

                            Text {
                                text: "Removed default packages:";
                                font-size: 14px;
                                horizontal-alignment: left;
                            }
                        }

                        remove_packages_touch := TouchArea {
                            width: removed_packages_rect.width;
                            height: removed_packages_rect.height;

                            remove_packages_tooltip := Tooltip {
                                text: "Default packages that are excluded from the firmware.";
                                active: remove_packages_touch.has-hover;
                                x: 0;
                                y: parent.height + 8px;
                            }
                        }
                    }

                    removed_packages_text := TextEdit {
                        text: root.removed_packages_text;
                        enabled: !busy && image_exists;
                        min-height: 60px;
                        placeholder-text: "none";
                        read-only: true;
                    }
                }
            }

            Tab {
                title: "Advanced settings";

                VerticalBox {
                    padding: 0px;
                    padding-top: 10px;

                    HorizontalBox {
                        padding: 0px;
                        z: 100;
                        rootfs_size_rect := Rectangle {
                            Text {
                                text: "RootFS size:";
                                font-size: 14px;
                                vertical-alignment: center;
                            }

                            rootfs_size_touch := TouchArea {
                                width: rootfs_size_rect.width;
                                height: rootfs_size_rect.height;

                                rootfs_size_tooltip := Tooltip {
                                    text: "Size of the root filesystem in MiB.";
                                    active: rootfs_size_touch.has-hover;
                                    x: 0;
                                    y: parent.height + 8px;
                                }
                            }
                        }

                        rootfs_size := LineEdit {
                            text <=> rootfs_size_value;
                            enabled: !busy && image_exists;
                            input-type: InputType.number;
                            placeholder_text: "default";
                        }
                    }

                    disabled_services_rect := Rectangle {
                        z: 90;
                        HorizontalBox {
                            padding: 0px;
                            Text {
                                text: "Disabled services:";
                                font-size: 14px;
                                horizontal-alignment: left;
                            }
                        }

                        disabled_services_touch := TouchArea {
                            width: disabled_services_rect.width;
                            height: disabled_services_rect.height;

                            disabled_services_tooltip := Tooltip {
                                text: "Space-separated list of services to disable in the firmware.";
                                active: disabled_services_touch.has-hover;
                                x: 0;
                                y: parent.height + 8px;
                            }
                        }
                    }

                    disabled_service_text := TextEdit {
                        text <=> root.disabled_service_text;
                        enabled: !busy && image_exists;
                        min-height: 60px;
                        placeholder-text: "none";
                    }

                    HorizontalBox {
                        padding: 0px;
                        z: 80;

                        overlay_path_rect := Rectangle {
                            width: 100px;
                            overlay_path_label := Text {
                                text: "Overlay folder:";
                                font-size: 14px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                                width: parent.width;
                            }

                            overlay_path_touch := TouchArea {
                                width: overlay_path_rect.width;
                                height: overlay_path_rect.height;

                                overlay_path_tooltip := Tooltip {
                                    text: "Path to the overlay folder which content will be added on top of the root filesystem.";
                                    active: overlay_path_touch.has-hover;
                                    x: 0;
                                    y: parent.height + 8px;
                                }
                            }
                        }

                        overlay_path_text := LineEdit {
                            text <=> root.overlay_path_text;
                            enabled: !busy && image_exists;
                            placeholder_text: "none";
                            read-only: false;
                        }

                        Button {
                            text: "Select folder";
                            enabled: !busy && image_exists;
                            clicked => {
                                select_overlay_folder_requested();
                            }
                        }
                    }

                    HorizontalBox {
                        padding: 0px;
                        z: 70;

                        build_path_rect := Rectangle {
                            width: overlay_path_rect.width;
                            build_path_label := Text {
                                text: "Build folder:";
                                font-size: 14px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                                width: parent.width;
                            }

                            build_path_touch := TouchArea {
                                width: build_path_rect.width;
                                height: build_path_rect.height;

                                build_path_tooltip := Tooltip {
                                    text: "Path to the build folder where the firmware images will be built.";
                                    active: build_path_touch.has-hover;
                                    x: 0;
                                    y: parent.height + 8px;
                                }
                            }
                        }

                        build_path_text := LineEdit {
                            text <=> root.build_path_text;
                            enabled: !busy;
                            placeholder_text: "none";
                            read-only: false;
                            edited(text) => {
                                build_path_edited(text);
                            }
                        }

                        Button {
                            text: "Select folder";
                            enabled: !busy;
                            clicked => {
                                select_build_folder_requested();
                            }
                        }
                    }
                }
            }
        }

        HorizontalBox {
            padding: 0px;
            spacing: 10px;

            Rectangle {
                horizontal-stretch: 1;
            }

            Button {
                text: "Open build folder";
                enabled: !busy && image_exists;
                clicked => {
                    open_build_folder_requested();
                }
            }

            build_button := Button {
                text: "Build firmware";
                primary: true;
                enabled: !busy && image_exists && root.packages_text != "";
                clicked => {
                    build_requested(root.packages_text);
                }
            }
        }

        Rectangle {
            background: Palette.control-background;
            border-width: 1px;
            border-color: Palette.border;
            border-radius: 4px;

            HorizontalBox {
                padding-top: 6px;
                padding-bottom: 6px;
                padding-left: 10px;
                padding-right: 10px;

                status_text := Text {
                    text: "Ready";
                    font-size: 12px;
                    horizontal-alignment: left;
                    vertical-alignment: center;

                    states [
                        fetch_failed when profiles_fetch_failed: {
                            text: "Failed to fetch profiles";
                        }
                        no_profile when selected_id == "": {
                            text: "Select profile";
                        }
                        missing_builder when !image_exists && build_status == "": {
                            text: "Missing image builder";
                        }
                        custom when build_status != "": {
                            text: build_status;
                        }
                    ]
                }

                VerticalBox {
                    width: 50%;
                    ProgressIndicator {
                        height: 10px;
                        progress: progress_value;
                        opacity: 0.0;
                        indeterminate: progress_value == 0.0 && progress_visible;

                        states [
                            visible_state when progress_visible: {
                                opacity: 1.0;
                                in {
                                    animate opacity { duration: 250ms; }
                                }
                                out {
                                    animate opacity { duration: 250ms; }
                                }
                            }
                        ]
                    }
                }
            }
        }
    }
}
